<?xml version="1.0" encoding="utf-8"?>
<!--
  LibChecker exceptions config.
  Each <Exception> has an 'unwanted' attribute (or '*' to match all unwanted strings).
  Child elements specify the matching condition (all must match = AND logic):
    <Album equals="..." />
    <Album contains="..." />
    <Artists contains="..." />
    <Title contains="..." />
    <Title equals="..." />
  Comparisons are case-sensitive to match tag values exactly.

  Audited 2026-06-02: all remaining exceptions are genuine track-specific exemptions.
  Bug-fix workaround (edit/Edition) removed - LibChecker now uses word-boundary
  matching for "edit" so "Edition" is never a false positive without needing an exception.
-->
<Exceptions>

  <!-- "Original Rappers" album legitimately contains 'original' -->
  <Exception unwanted="original">
    <Album equals="Original Rappers" />
  </Exception>

  <!-- KRS-One tracks legitimately reference 'original' -->
  <Exception unwanted="original">
    <Artists contains="KRS-One" />
  </Exception>

  <!-- Bebe Rexha radio edit - intentional -->
  <Exception unwanted="edit">
    <Title contains="Going To Be Alright" />
  </Exception>

  <!-- Dr. Dre / Eminem - intentional edit -->
  <Exception unwanted="edit">
    <Title contains="Medicine Man" />
  </Exception>

  <!-- Kid Cudi track title that happens to contain 'soundtrack' -->
  <Exception unwanted="soundtrack">
    <Title equals="Soundtrack 2 My Life" />
  </Exception>

  <!-- Agatha All Along TV cast recording - all tag rules exempt -->
  <Exception unwanted="*">
    <Artists contains="Agatha All Along" />
  </Exception>

  <!-- Eric Thomas motivational bonus interview - exempt from tag cleanup -->
  <Exception unwanted="*">
    <Artists contains="Eric Thomas" />
    <Title contains="BONUS INTERVIEW" />
  </Exception>

  <!-- Akira The Don;Scott Adams - 'VERSION' is part of the official title -->
  <Exception unwanted="version">
    <Artists contains="Scott Adams" />
    <Title contains="BETTER VERSION OF YOURSELF" />
  </Exception>

  <!-- Akira The Don;Alan Watts - 'VERSION' is part of official titles -->
  <Exception unwanted="version">
    <Artists contains="Alan Watts" />
    <Title contains="Beware of Virtue" />
  </Exception>

  <Exception unwanted="version">
    <Artists contains="Alan Watts" />
    <Title contains="The Highest Virtue" />
  </Exception>

  <!-- Eels B-sides compilation - album "Useless Trinkets: B-sides, Soundtracks, Rarities and Unreleased" legitimately contains 'Soundtracks' -->
  <Exception unwanted="soundtrack">
    <Artists contains="Eels" />
    <Album contains="Useless Trinkets" />
  </Exception>

</Exceptions>
