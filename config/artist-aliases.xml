<?xml version="1.0" encoding="utf-8"?>
<!--
  Artist name aliases for duplicate detection.
  Maps old/alternative artist names to their current canonical name.

  When the library has tracks stored under an old name (e.g. "Kanye West") and
  a new batch arrives under the canonical name (e.g. "Ye"), without an alias the
  duplicate checker sees different primary artists and misses the match - silently
  creating duplicate tracks in the library.

  Both directions are checked: if library has "Kanye West" and new file has "Ye",
  the duplicate is flagged. If library has "Ye" and new file has "Kanye West",
  it is also flagged.

  Format: from="old name" to="canonical name"
-->
<ArtistAliases>
  <!-- "Ye" is the artist's legal name; library uses "Kanye West" as the canonical folder name.
       This alias ensures duplicate detection bridges both names in either direction. -->
  <Alias from="Ye" to="Kanye West" />
</ArtistAliases>
