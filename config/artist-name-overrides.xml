<?xml version="1.0" encoding="utf-8"?>
<!--
  Canonical artist name casing overrides for TagFixer.
  Add an entry for any artist whose name intentionally uses non-standard casing
  (e.g. all-lowercase, stylized caps). TagFixer will use these instead of title-casing.

  Applies to both primary and featured (secondary) artists. One entry per artist handles
  all positions. Example: "Scott Adams" entry will preserve casing whether Scott Adams
  appears as primary artist or as featured (e.g. "Akira The Don; Scott adams" -> "Akira The Don; Scott Adams").

  Matching is case-insensitive so only the canonical form is needed.
-->
<ArtistOverrides>

  <!-- Lowercase / all-lowercase styles -->
  <Artist canonical="blink-182" />
  <Artist canonical="iann dior" />
  <Artist canonical="mike." />

  <!-- All-caps names and acronyms -->
  <Artist canonical="DMX" />
  <Artist canonical="FIFTY FIFTY" />
  <Artist canonical="XV" />
  <Artist canonical="H.E.A.T" />
  <Artist canonical="KSI" />
  <Artist canonical="LL COOL J" />
  <Artist canonical="MIKA" />
  <Artist canonical="MKTO" />
  <Artist canonical="MOUNT WESTMORE" />
  <Artist canonical="N.W.A" />
  <Artist canonical="NAV" />
  <Artist canonical="POLO G" />
  <Artist canonical="TMRWNITE" />
  <Artist canonical="YG" />

  <!-- Partial caps / acronym prefix -->
  <Artist canonical="DC The Don" />
  <Artist canonical="DJ Khaled" />
  <Artist canonical="PJ Simas" />
  <Artist canonical="KOTA The Friend" />
  <Artist canonical="KRS-One" />
  <Artist canonical="Juice WRLD" />
  <Artist canonical="NLE Choppa" />
  <Artist canonical="OutKast" />
  <Artist canonical="The Kid LAROI" />
  <Artist canonical="YNW Melly" />

  <!-- Hyphenated names where letter after hyphen must be capped -->
  <Artist canonical="Eazy-E" />
  <Artist canonical="G-Eazy" />
  <!-- variant covers the stylized Unicode form used by some streaming providers (Ÿ = U+0178) -->
  <Artist canonical="Jay-Z" variant="JAŸ-Z" />
  <Artist canonical="T-Pain" />
  <Artist canonical="Bone Thugs-N-Harmony" />

  <!-- Digit-prefixed names -->
  <Artist canonical="2Pac" />
  <Artist canonical="24kGoldn" />
  <Artist canonical="Rappin' 4-Tay" />

  <!-- CamelCase / internal caps -->
  <Artist canonical="B.o.B" />
  <Artist canonical="BigXthaPlug" />
  <Artist canonical="DaBaby" />
  <Artist canonical="PinkPantheress" />
  <Artist canonical="TeeManay" />
  <Artist canonical="YoungBoy Never Broke Again" />

  <!-- Punctuation-sensitive names -->
  <Artist canonical="T.I" />

  <!-- Standard title-case (preserved explicitly for auditability) -->
  <Artist canonical="Scott Adams" />
  <Artist canonical="Terence McKenna" />

</ArtistOverrides>
